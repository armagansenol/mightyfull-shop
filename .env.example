# Shopify storefront domain, e.g. mystore.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Shopify Admin API access token. App must have read_own_subscription_contracts scope.
SHOPIFY_ADMIN_TOKEN=

# Klaviyo private API key (pk_...). Used as `Klaviyo-API-Key {key}` on the Events API.
# Shared with the welcome-email route — set once on the storefront project.
KLAVIYO_PRIVATE_API_KEY=

# Shared secret for protecting the cron endpoint. Vercel Cron sends this as
# `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=
